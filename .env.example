# Gateway authentication — set via `wrangler secret put GATEWAY_API_KEY` in production.
# All /v1/* mutation endpoints require `Authorization: Bearer <key>` or `x-api-key: <key>`.
# Omit (or leave blank) only in local dev where the Worker is not publicly reachable.
GATEWAY_API_KEY=replace-with-strong-random-secret

# Cloudflare Workers AI REST fallback for local wrangler dev --local
# Keep true to use Workers AI through the fail-closed free-tier neuron budget.
WORKERS_AI_ENABLED=true
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_WORKERS_AI_API_KEY=replace-with-cloudflare-workers-ai-token

# Provider keys — models auto-activate when their key is present
GROQ_API_KEY=replace-with-groq-api-key
GEMINI_API_KEY=replace-with-gemini-api-key
VOYAGE_API_KEY=replace-with-voyage-api-key
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
NVIDIA_API_KEY=
PLAYGROUND_ENABLED=false
AUTO_ISSUE_KEYS=false

# Optional continuous eval results. Keys can be "<provider>:<model>" or registry ids.
# Values nudge routing without bypassing health, quota headroom, cooldown, or capability filters.
MODEL_EVALUATIONS_JSON={"gemini:gemini-2.0-flash-lite":{"qualityScore":0.86,"taskSuccessRate":0.91,"freshness":0.95,"sampleCount":24}}
