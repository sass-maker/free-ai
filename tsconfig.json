{
  "extends": "@saas-maker/tsconfig/vite.json",
  "compilerOptions": {
    "types": ["@cloudflare/workers-types", "vitest/globals"],
    "noPropertyAccessFromIndexSignature": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "playground/src/**/*.ts",
    "playground/src/**/*.tsx",
    "vitest.config.ts"
  ]
}
