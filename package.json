{
  "name": "@sass-maker/ai-gateway",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/mod.ts",
      "import": "./src/mod.ts"
    }
  },
  "scripts": {
    "env:sync": "node scripts/sync-dev-vars.mjs",
    "dev": "wrangler dev --remote",
    "dev:local": "npm run env:sync && wrangler dev --local",
    "deploy": "pnpm --dir site install --no-frozen-lockfile && pnpm --dir site build && wrangler deploy",
    "deploy:cloudflare": "node scripts/deploy-cloudflare.mjs",
    "build:playground": "vite build --config playground/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build:playground",
    "check": "npm run typecheck && npm test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:live": "playwright test -c playwright.live.config.ts",
    "test:e2e:live:update": "playwright test -c playwright.live.config.ts --update-snapshots",
    "test:all": "npm run check && npm run test:e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/swagger-ui": "0.6.1",
    "@hono/zod-openapi": "1.3.0",
    "@hookform/resolvers": "5.2.2",
    "@saas-maker/ops": "^1.0.0",
    "@tanstack/react-query": "5.100.1",
    "hono": "4.12.15",
    "openai": "6.34.0",
    "p-limit": "7.3.0",
    "p-retry": "8.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.73.1",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.15.0",
    "@cloudflare/workers-types": "4.20260424.1",
    "@playwright/test": "1.59.1",
    "@saas-maker/eslint-config": "^1.0.4",
    "@saas-maker/prettier-config": "^1.0.0",
    "@saas-maker/tsconfig": "^1.0.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "husky": "9.1.7",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "wrangler": "4.85.0"
  },
  "prettier": "@saas-maker/prettier-config"
}
