---
const _title = 'Free AI Gateway — One API key, 8 free LLM providers';
const _description =
  'OpenAI-compatible gateway that routes across Groq, Gemini, Cerebras, SambaNova, NVIDIA, OpenRouter, Voyage, and Workers AI — auto-failover, no credit card, $0 per request.';
const _gw = 'https://free-ai-gateway.sarthakagrawal927.workers.dev';
const _lb = '{';
const _rb = '}';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={gw} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=JetBrains+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
    <style is:inline>
      :root{--bg:#050a0e;--bg-raised:#0a1118;--bg-card:#0d1820;--surface:#121f2b;--border:#1a2d3a;--border-bright:#245068;--text:#e4edf3;--text-secondary:#7d9bae;--text-muted:#4a6575;--brand:#0ea5e9;--brand-glow:rgba(14,165,233,0.15);--emerald:#10b981;--amber:#f59e0b;--font-display:'Instrument Serif',Georgia,serif;--font-body:'DM Sans',system-ui,sans-serif;--font-mono:'JetBrains Mono',ui-monospace,monospace}
      *{box-sizing:border-box;margin:0;padding:0}
      html{scroll-behavior:smooth}
      body{font-family:var(--font-body);color:var(--text);background:var(--bg);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}

      @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
      @keyframes fadeIn{from{opacity:0}to{opacity:1}}
      @keyframes pulse-ring{0%{transform:scale(.9);opacity:.6}100%{transform:scale(1.4);opacity:0}}

      .afu{opacity:0;animation:fadeUp .7s cubic-bezier(.16,1,.3,1) forwards}
      .d1{animation-delay:.1s}.d2{animation-delay:.2s}.d3{animation-delay:.3s}.d4{animation-delay:.4s}
      .d5{animation-delay:.5s}.d6{animation-delay:.6s}.d7{animation-delay:.7s}.d8{animation-delay:.8s}

      .nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 2.5rem;height:56px;background:rgba(5,10,14,.7);backdrop-filter:blur(20px) saturate(1.4);border-bottom:1px solid var(--border);animation:fadeIn .5s ease forwards}
      .nav-left{display:flex;align-items:center;gap:2.5rem}
      .nav-brand{display:flex;align-items:center;gap:.6rem;text-decoration:none;color:var(--text)}
      .nav-brand svg{width:22px;height:22px}
      .nav-brand-text{font-weight:600;font-size:.9rem;letter-spacing:-.01em}
      .nav-brand-text span{color:var(--text-muted);font-weight:400;margin-left:.15rem}
      .nav-links{display:flex;gap:.15rem;list-style:none}
      .nav-links a{display:flex;align-items:center;gap:.35rem;padding:.35rem .75rem;border-radius:6px;text-decoration:none;font-size:.8rem;font-weight:500;color:var(--text-secondary);transition:all .2s;letter-spacing:.01em}
      .nav-links a:hover{color:var(--text);background:rgba(14,165,233,.08)}
      .nav-links a.active{color:var(--brand);background:rgba(14,165,233,.1)}
      .nav-right{display:flex;align-items:center;gap:.75rem}
      .nav-status{display:flex;align-items:center;gap:.4rem;font-size:.72rem;color:var(--emerald);font-weight:500;letter-spacing:.02em}
      .status-dot{position:relative;width:6px;height:6px}
      .status-dot::before{content:'';position:absolute;inset:0;border-radius:50%;background:var(--emerald)}
      .status-dot::after{content:'';position:absolute;inset:-3px;border-radius:50%;background:var(--emerald);animation:pulse-ring 2s ease-out infinite}
      .nav-cta{display:inline-flex;align-items:center;gap:.35rem;padding:.35rem .85rem;border-radius:6px;font-size:.8rem;font-weight:500;text-decoration:none;color:var(--bg);background:var(--brand);transition:all .2s}
      .nav-cta:hover{background:#38bdf8;transform:translateY(-1px)}
      .nav-cta svg{width:14px;height:14px}

      .hero{position:relative;padding:10rem 2rem 6rem;text-align:center;overflow:hidden}
      .hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 50% 0%,rgba(14,165,233,.12),transparent),radial-gradient(ellipse 40% 60% at 80% 20%,rgba(16,185,129,.06),transparent),radial-gradient(ellipse 50% 40% at 20% 40%,rgba(14,165,233,.04),transparent)}
      .hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(26,45,58,.3) 1px,transparent 1px),linear-gradient(90deg,rgba(26,45,58,.3) 1px,transparent 1px);background-size:64px 64px;mask-image:radial-gradient(ellipse 70% 50% at 50% 30%,black,transparent)}
      .hero-content{position:relative;max-width:720px;margin:0 auto}
      .hero-badge{display:inline-flex;align-items:center;gap:.5rem;padding:.3rem .4rem .3rem .35rem;border-radius:999px;border:1px solid var(--border-bright);background:rgba(14,165,233,.06);font-size:.72rem;font-weight:500;color:var(--text-secondary);letter-spacing:.03em;margin-bottom:1.75rem}
      .hero-badge-dot{width:18px;height:18px;border-radius:50%;background:linear-gradient(135deg,var(--brand),var(--emerald));display:flex;align-items:center;justify-content:center}
      .hero-badge-dot svg{width:10px;height:10px;stroke:white}
      h1{font-family:var(--font-display);font-size:clamp(2.8rem,6vw,4.5rem);font-weight:400;line-height:1.05;letter-spacing:-.02em;margin-bottom:1.25rem}
      h1 em{font-style:italic;color:var(--brand)}
      .hero-sub{font-size:1.1rem;color:var(--text-secondary);max-width:500px;margin:0 auto 2.5rem;line-height:1.65}
      .hero-actions{display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap}

      .btn{display:inline-flex;align-items:center;gap:.5rem;padding:.7rem 1.35rem;border-radius:8px;font-size:.85rem;font-weight:500;font-family:var(--font-body);text-decoration:none;transition:all .25s cubic-bezier(.16,1,.3,1);cursor:pointer;border:none}
      .btn svg{width:16px;height:16px}
      .btn-primary{background:var(--brand);color:var(--bg);box-shadow:0 0 0 1px rgba(14,165,233,.3),0 4px 16px rgba(14,165,233,.2)}
      .btn-primary:hover{background:#38bdf8;box-shadow:0 0 0 1px rgba(14,165,233,.5),0 8px 30px rgba(14,165,233,.3);transform:translateY(-2px)}
      .btn-ghost{color:var(--text-secondary);border:1px solid var(--border);background:transparent}
      .btn-ghost:hover{color:var(--text);border-color:var(--border-bright);background:rgba(255,255,255,.03);transform:translateY(-2px)}

      .stat-bar{display:flex;justify-content:center;gap:3rem;padding:2.5rem 2rem;margin-top:1.5rem}
      .stat{text-align:center}
      .stat-value{font-family:var(--font-mono);font-size:1.6rem;font-weight:500;color:var(--text);letter-spacing:-.03em}
      .stat-value .accent{color:var(--brand)}
      .stat-label{font-size:.72rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.08em;margin-top:.25rem}

      .features-section{max-width:1080px;margin:0 auto;padding:4rem 2rem 6rem}
      .section-label{font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--brand);margin-bottom:.75rem}
      .section-title{font-family:var(--font-display);font-size:clamp(1.6rem,3vw,2.2rem);font-weight:400;line-height:1.15;margin-bottom:3rem;max-width:500px}
      .features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border-radius:16px;overflow:hidden;border:1px solid var(--border)}
      .feature{background:var(--bg-card);padding:2rem;transition:background .3s;position:relative}
      .feature:hover{background:var(--surface)}
      .feature-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem}
      .feature-icon svg{width:20px;height:20px;position:relative;z-index:1}
      .feature-icon.blue{background:rgba(14,165,233,.12);color:var(--brand)}
      .feature-icon.green{background:rgba(16,185,129,.12);color:var(--emerald)}
      .feature-icon.amber{background:rgba(245,158,11,.12);color:var(--amber)}
      .feature h3{font-family:var(--font-body);font-size:.95rem;font-weight:600;margin-bottom:.5rem;letter-spacing:-.01em}
      .feature p{font-size:.82rem;color:var(--text-secondary);line-height:1.6}

      .code-section{max-width:1080px;margin:0 auto;padding:2rem 2rem 8rem;display:grid;grid-template-columns:1fr 1.25fr;gap:4rem;align-items:center}
      .code-intro h2{font-family:var(--font-display);font-size:clamp(1.6rem,3vw,2.2rem);font-weight:400;line-height:1.15;margin-bottom:1rem}
      .code-intro p{color:var(--text-secondary);font-size:.9rem;line-height:1.7;margin-bottom:1.5rem}
      .code-intro code{font-family:var(--font-mono);font-size:.82em;color:var(--brand);background:var(--brand-glow);padding:.15em .4em;border-radius:4px}
      .code-window{background:var(--bg-raised);border:1px solid var(--border);border-radius:12px;overflow:hidden;box-shadow:0 24px 80px rgba(0,0,0,.4),0 0 0 1px rgba(14,165,233,.05)}
      .code-toolbar{display:flex;align-items:center;gap:.5rem;padding:.75rem 1rem;border-bottom:1px solid var(--border);background:rgba(255,255,255,.015)}
      .code-dot{width:10px;height:10px;border-radius:50%;background:var(--border-bright)}
      .code-dot:first-child{background:#ef4444;opacity:.7}
      .code-dot:nth-child(2){background:#f59e0b;opacity:.7}
      .code-dot:nth-child(3){background:#10b981;opacity:.7}
      .code-tab{margin-left:.75rem;font-family:var(--font-mono);font-size:.7rem;color:var(--text-muted);padding:.2rem .6rem;border-radius:4px;background:rgba(255,255,255,.04);cursor:pointer;transition:color .15s,background .15s}
      .code-tab.active{color:var(--text);background:rgba(255,255,255,.1)}
      .code-body{padding:1.25rem 1.5rem;font-family:var(--font-mono);font-size:.78rem;line-height:1.85;overflow-x:auto;color:var(--text-secondary);white-space:pre}
      .code-body .cm{color:var(--text-muted);font-style:italic}
      .code-body .cmd{color:var(--emerald)}
      .code-body .url{color:var(--brand)}
      .code-body .fl{color:var(--amber)}
      .code-body .str{color:#a78bfa}
      .code-body .key{color:#f472b6}
      .code-body .val{color:#34d399}

      .proof-strip{background:var(--bg-raised);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:2rem 2rem}
      .proof-inner{display:flex;justify-content:center;align-items:center;max-width:860px;margin:0 auto}
      .proof-item{flex:1;text-align:center;padding:0 2rem}
      .proof-num{font-family:var(--font-mono);font-size:2rem;font-weight:500;color:var(--text);letter-spacing:-.04em;line-height:1}
      .proof-accent{color:var(--emerald)}
      .proof-label{font-size:.75rem;font-weight:600;color:var(--text-secondary);margin-top:.4rem;letter-spacing:.01em}
      .proof-sub{font-size:.65rem;color:var(--text-muted);margin-top:.2rem}
      .proof-divider{width:1px;height:48px;background:var(--border);flex-shrink:0}
      @media(max-width:600px){.proof-inner{flex-direction:column;gap:1.5rem}.proof-divider{width:48px;height:1px}}

      .footer{border-top:1px solid var(--border);padding:3rem 2rem;max-width:1080px;margin:0 auto;display:flex;justify-content:space-between;align-items:flex-start}
      .footer-brand{display:flex;align-items:center;gap:.5rem;font-weight:600;font-size:.85rem;color:var(--text);margin-bottom:.5rem}
      .footer-brand svg{width:18px;height:18px}
      .footer-copy{font-size:.72rem;color:var(--text-muted)}
      .footer-links{display:flex;gap:2rem}
      .footer-col h4{font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);margin-bottom:.75rem}
      .footer-col a{display:block;color:var(--text-secondary);text-decoration:none;font-size:.8rem;padding:.2rem 0;transition:color .15s}
      .footer-col a:hover{color:var(--text)}

      @media(max-width:768px){
        .nav{padding:0 1.25rem}
        .nav-right{display:none}
        .hero{padding:8rem 1.25rem 4rem}
        .stat-bar{gap:1.5rem;flex-wrap:wrap}
        .features-grid{grid-template-columns:1fr}
        .code-section{grid-template-columns:1fr;gap:2rem;padding-bottom:4rem}
        .footer{flex-direction:column;gap:2rem}
        .footer-links{gap:1.5rem}
      }
    </style>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-left">
        <a class="nav-brand" href="/">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z" fill="rgba(14,165,233,0.15)" stroke="currentColor"/>
            <path d="M2 17l10 5 10-5" opacity="0.5"/>
            <path d="M2 12l10 5 10-5" opacity="0.75"/>
          </svg>
          <span class="nav-brand-text">sass-maker <span>/ ai gateway</span></span>
        </a>
        <ul class="nav-links">
          <li><a href="/" class="active">Home</a></li>
          <li><a href="/getting-started">Docs</a></li>
          <li><a href="/dashboard">Dashboard</a></li>
        </ul>
      </div>
      <div class="nav-right">
        <a class="nav-status" href={`${gw}/health`} target="_blank" style="text-decoration:none">
          <span class="status-dot"></span>
          Live health status
        </a>
        <a class="nav-cta" href="/getting-started">
          Get API Key
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-grid"></div>
      <div class="hero-content">
        <div class="hero-badge afu d1">
          <span class="hero-badge-dot">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 8h8M8 4v8"/></svg>
          </span>
          sass-maker module &mdash; v1.0
        </div>
        <h1 class="afu d2">Call <em>40+ free</em> LLMs<br/>from one OpenAI key</h1>
        <p class="hero-sub afu d3">
          Drop-in OpenAI-compatible gateway across 8 free providers &mdash;
          Groq, Gemini, Cerebras, SambaNova, NVIDIA, OpenRouter, Voyage,
          and Workers AI. Auto-failover when one provider throttles.
        </p>
        <div class="hero-actions afu d4">
          <a class="btn btn-primary" href="/getting-started">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10.5 3.5a2 2 0 1 1-4 0 2 2 0 0 1 4 0z"/><path d="M5.5 6.5l-2 4 4.5 4.5 4-2-2-2-2.5-2.5z"/></svg>
            Get my free API key
          </a>
          <a class="btn btn-ghost" href={`${gw}/v1/routing/status`} target="_blank">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8" cy="8" r="6"/><path d="M8 5v3l2 2"/></svg>
            See live provider status
          </a>
        </div>
      </div>
      <div class="stat-bar afu d5">
        <div class="stat">
          <div class="stat-value"><span class="accent">8</span></div>
          <div class="stat-label">Free Providers</div>
        </div>
        <div class="stat">
          <div class="stat-value">40<span class="accent">+</span></div>
          <div class="stat-label">Chat Models</div>
        </div>
        <div class="stat">
          <div class="stat-value"><span class="accent">$0</span></div>
          <div class="stat-label">Per Request</div>
        </div>
        <div class="stat">
          <div class="stat-value"><span class="accent">SSE</span></div>
          <div class="stat-label">Streaming</div>
        </div>
      </div>
    </section>

    <section class="proof-strip">
      <div class="proof-inner">
        <div class="proof-item">
          <div class="proof-num" id="proof-requests"><span class="proof-accent">—</span></div>
          <div class="proof-label">Free requests routed</div>
          <div class="proof-sub">$0 in provider API costs</div>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <div class="proof-num"><span class="proof-accent">8</span></div>
          <div class="proof-label">Provider fallback chain</div>
          <div class="proof-sub">Auto-skips throttled or failed providers</div>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <div class="proof-num" id="proof-savings"><span class="proof-accent">$0</span></div>
          <div class="proof-label">vs. GPT-4o mini pricing</div>
          <div class="proof-sub">Paid APIs charge ~$0.30/1K requests</div>
        </div>
      </div>
    </section>

    <section class="features-section">
      <div class="section-label afu d1">Capabilities</div>
      <div class="section-title afu d2">One endpoint. 8 providers. Auto-failover when one breaks.</div>
      <div class="features-grid">
        <div class="feature afu d3">
          <div class="feature-icon blue">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 3h5v5"/><path d="M21 3l-7 7"/><path d="M8 21H3v-5"/><path d="M3 21l7-7"/><path d="M21 14v3a2 2 0 01-2 2h-3"/><path d="M3 10V7a2 2 0 012-2h3"/></svg>
          </div>
          <h3>Multi-Provider Routing</h3>
          <p>Routes across all 8 providers — Groq, Gemini, SambaNova, NVIDIA, Cerebras, OpenRouter, Voyage, and Workers AI — with health-aware fallback.</p>
        </div>
        <div class="feature afu d4">
          <div class="feature-icon green">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3>Health-Aware Selection</h3>
          <p>Tracks success rates, latency, and cooldowns per model. Unhealthy providers are automatically skipped.</p>
        </div>
        <div class="feature afu d5">
          <div class="feature-icon amber">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3>Streaming SSE</h3>
          <p>Full Server-Sent Events streaming for chat completions and responses API. Drop-in OpenAI SDK compatible.</p>
        </div>
        <div class="feature afu d5">
          <div class="feature-icon green">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><circle cx="19" cy="5" r="2"/><circle cx="5" cy="5" r="2"/><circle cx="19" cy="19" r="2"/><circle cx="5" cy="19" r="2"/><path d="M14.5 10L17 7M9.5 10L7 7M14.5 14l2.5 3M9.5 14L7 17"/></svg>
          </div>
          <h3>Embeddings</h3>
          <p>Generate embeddings via Workers AI, Gemini, or Voyage AI. Standard OpenAI embeddings format.</p>
        </div>
        <div class="feature afu d6">
          <div class="feature-icon blue">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
          </div>
          <h3>Built-in Analytics</h3>
          <p>Request logging, per-provider stats, and a live usage dashboard. Monitor everything from /v1/analytics.</p>
        </div>
        <div class="feature afu d7">
          <div class="feature-icon amber">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          </div>
          <h3>Rate Limiting</h3>
          <p>IP-based rate limiting on public endpoints. Per-provider daily limits with configurable thresholds.</p>
        </div>
      </div>
    </section>

    <section class="code-section">
      <div class="code-intro afu d2">
        <div class="section-label">Quick Start</div>
        <h2>Up and running in one curl</h2>
        <p>
          Point your existing OpenAI SDK or curl commands at the gateway.
          Set <code>model: "auto"</code>
          and the gateway handles provider selection, retries, and failover.
        </p>
        <p style="font-size:.78rem;color:var(--text-muted);margin-top:-.5rem">
          Heads up: this aggregates free provider tiers — best-effort, no SLA.
          Per-IP limit is ~10 burst / ~20 rpm, each model has a daily cap, and the gateway returns <code>503</code> only when every capable model is rate-limited — rate-limit windows reset within minutes.
          For production throughput, pin a model and bring your own keys.
        </p>
        <a class="btn btn-primary" href="/getting-started" style="margin-top: 0.5rem;">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h12v10H2z"/><path d="M2 6h12"/></svg>
          Full API reference
        </a>
      </div>
      <div class="code-window afu d4">
        <div class="code-toolbar">
          <span class="code-dot"></span>
          <span class="code-dot"></span>
          <span class="code-dot"></span>
          <span class="code-tab active" data-panel="curl">terminal</span>
          <span class="code-tab" data-panel="sdk">openai sdk</span>
        </div>
        <div id="panel-curl" class="code-body"><span class="cm"># 1. Check which providers are live right now (no key needed)</span>
<span class="cmd">curl</span> <span class="url">{gw}/v1/routing/status</span>

<span class="cm"># 2. Send your first chat completion</span>
<span class="cmd">curl</span> <span class="url">{gw}/v1/chat/completions</span> \
  <span class="fl">-H</span> <span class="str">"Authorization: Bearer $KEY"</span> \
  <span class="fl">-H</span> <span class="str">"Content-Type: application/json"</span> \
  <span class="fl">-d</span> <span class="str">'{lb}
  <span class="key">"model"</span>: <span class="val">"auto"</span>,
  <span class="key">"messages"</span>: [{lb}
    <span class="key">"role"</span>: <span class="val">"user"</span>,
    <span class="key">"content"</span>: <span class="val">"Hello!"</span>
  {rb}]
{rb}'</span>

<span class="cm"># Embeddings</span>
<span class="cmd">curl</span> <span class="url">{gw}/v1/embeddings</span> \
  <span class="fl">-H</span> <span class="str">"Authorization: Bearer $KEY"</span> \
  <span class="fl">-H</span> <span class="str">"Content-Type: application/json"</span> \
  <span class="fl">-d</span> <span class="str">'{lb}
  <span class="key">"model"</span>: <span class="val">"@cf/baai/bge-base-en-v1.5"</span>,
  <span class="key">"input"</span>: <span class="val">"Hello world"</span>
{rb}'</span></div>
        <div id="panel-sdk" class="code-body" style="display:none"><span class="cm">// npm install openai  (already installed if you use OpenAI SDK)</span>
<span class="key">import</span> <span class="val">OpenAI</span> <span class="key">from</span> <span class="str">'openai'</span>;

<span class="key">const</span> <span class="val">client</span> = <span class="key">new</span> <span class="val">OpenAI</span>({lb}
  <span class="key">baseURL</span>: <span class="str">'{gw}/v1'</span>,
  <span class="key">apiKey</span>: process.env.<span class="val">GATEWAY_API_KEY</span>,
{rb});

<span class="cm">// Chat completion — same params as OpenAI</span>
<span class="key">const</span> <span class="val">chat</span> = <span class="key">await</span> client.chat.completions.<span class="cmd">create</span>({lb}
  <span class="key">model</span>: <span class="str">'auto'</span>,
  <span class="key">extra_body</span>: {lb} <span class="key">project_id</span>: <span class="str">'my_project'</span> {rb},
  <span class="key">messages</span>: [{lb} <span class="key">role</span>: <span class="str">'user'</span>, <span class="key">content</span>: <span class="str">'Hello!'</span> {rb}],
{rb});
console.<span class="cmd">log</span>(chat.choices[0].message.content);

<span class="cm">// Embeddings</span>
<span class="key">const</span> <span class="val">emb</span> = <span class="key">await</span> client.embeddings.<span class="cmd">create</span>({lb}
  <span class="key">model</span>: <span class="str">'gemini-embedding-001'</span>,
  <span class="key">input</span>: <span class="str">'Hello world'</span>,
{rb});
console.<span class="cmd">log</span>(emb.data[0].embedding.length + <span class="str">' dims'</span>);</div>
      </div>
      <script>
        document.querySelectorAll('.code-tab[data-panel]').forEach(function(t) {
          t.addEventListener('click', function() {
            document.querySelectorAll('.code-tab[data-panel]').forEach(function(x) { x.classList.remove('active'); });
            t.classList.add('active');
            document.querySelectorAll('#panel-curl,#panel-sdk').forEach(function(p) { p.style.display = 'none'; });
            document.getElementById('panel-' + t.dataset.panel).style.display = 'block';
          });
        });
      </script>
      <script>
        (function() {
          fetch('https://free-ai-gateway.sarthakagrawal927.workers.dev/v1/stats/providers')
            .then(function(r) { return r.ok ? r.json() : null; })
            .then(function(data) {
              if (!data || !data.stats) return;
              var total = data.stats.reduce(function(s, p) { return s + (p.total_attempts || 0); }, 0);
              if (total < 1) return;
              var rEl = document.getElementById('proof-requests');
              var sEl = document.getElementById('proof-savings');
              if (rEl) rEl.innerHTML = '<span class="proof-accent">' + total.toLocaleString() + '</span>';
              if (sEl) {
                // GPT-4o mini blended: ~$0.30 per 1 000 requests (500 in + 300 out tokens avg)
                var dollars = total * 0.0003;
                var text = dollars < 0.01
                  ? '$0'
                  : dollars < 1
                    ? Math.round(dollars * 100) + '¢'
                    : '$' + dollars.toFixed(2);
                sEl.innerHTML = '<span class="proof-accent">' + text + ' saved</span>';
              }
            })
            .catch(function() {});
        })();
      </script>
